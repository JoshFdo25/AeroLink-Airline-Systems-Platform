datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
  FLIGHT_CREW
}

model Passenger {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String?  // Hashed via bcrypt
  firstName      String
  lastName       String
  role           Role     @default(USER)
  passportNumber String?  // Encrypted via AES-256
  kycVerified    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Flight {
  id             String   @id @default(uuid())
  flightNumber   String   @unique
  origin         String
  destination    String
  departureTime  DateTime
  arrivalTime    DateTime
  price          Float
  availableSeats Int      @default(0)
  bookedSeats    String[] @default([])
  status         String   @default("SCHEDULED") // SCHEDULED, DELAYED, CANCELLED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Booking {
  id             String        @id @default(uuid())
  passengerId    String
  flightId       String
  seatNumber     String
  paymentToken   String        // PCI-DSS compliant token (e.g. "tok_visa")
  price          Float
  status         BookingStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum BaggageStatus {
  CHECKED_IN
  LOADED
  IN_TRANSIT
  READY_FOR_PICKUP
  CLAIMED
}

model Baggage {
  id             String        @id @default(uuid())
  passengerId    String
  flightId       String
  status         BaggageStatus @default(CHECKED_IN)
  location       String        // e.g., "Terminal 1 Counter", "Aircraft Hold", "Carousel 4"
  updatedAt      DateTime      @updatedAt
  createdAt      DateTime      @default(now())
}
