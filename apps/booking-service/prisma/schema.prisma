generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-booking"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Booking {
  id             String        @id @default(uuid())
  passengerId    String
  flightId       String
  paymentToken   String        // PCI-DSS compliant token (e.g. "tok_visa")
  price          Float
  status         BookingStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}
